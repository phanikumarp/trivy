# PLACEHOLDER — Do NOT commit real private key material here.
# This file must be generated before running integration tests.
# Run the following command from the repo root to generate a fresh
# self-signed key/cert pair for local testing:
#
#   openssl req -x509 -newkey rsa:4096 -keyout integration/data/certs/key.pem \
#     -out integration/data/certs/cert.pem -days 365 -nodes \
#     -subj "/CN=localhost"
